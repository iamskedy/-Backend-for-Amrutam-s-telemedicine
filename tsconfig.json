{"include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "generated", "prisma.config.ts"],
  "compilerOptions": {
    "rootDir": "./src",             
    "outDir": "./dist",              

    "module": "commonjs",           
    "moduleResolution": "node",     
    "target": "es2021",              
    "types": ["node"],              

    "sourceMap": true,
    "declaration": false,            
    "declarationMap": false,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,

    "strict": true,
    "esModuleInterop": true,         
    "resolveJsonModule": true,       
    "skipLibCheck": true,
    "moduleDetection": "force",

    "verbatimModuleSyntax": false,  

    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
}
}